# Production Environment Variables
# Sign Language Translation API

# ============================================================================
# IMPORTANT: Copy this to .env and fill in real values
# Never commit .env files with real credentials
# ============================================================================

# Environment
ENVIRONMENT=production
DEBUG=False

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sign_language_db
POSTGRES_DB=sign_language_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_RANDOM_STRING_HERE
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_V1_PREFIX=/api
PORT=8000
HOST=0.0.0.0

# CORS - Add your frontend URLs
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# File Storage
UPLOAD_DIR=./uploads
MODELS_DIR=./models
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes

# ML Configuration
WHISPER_MODEL_SIZE=base  # tiny, base, small, medium, large
BATCH_SIZE=8
DEVICE=cpu  # cpu or cuda

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Email (for password reset - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# Sentry (Error Tracking - optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Storage (S3 - optional)
S3_BUCKET=sign-language-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# Feature Flags
ENABLE_SIGNUP=True
ENABLE_VIDEO_UPLOAD=True
ENABLE_MODEL_TRAINING=True

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=9090

# ============================================================================
# HOW TO GENERATE SECRET_KEY:
# Run in Python: 
# import secrets; print(secrets.token_urlsafe(32))
# ============================================================================

