# Application Settings
APP_NAME="Sign Language Translator API"
APP_VERSION="1.0.0"
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY="your-secret-key-change-this-in-production-use-openssl-rand-hex-32"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# For development (SQLite):
DATABASE_URL="sqlite+aiosqlite:///./sqlitedb.db"

# For production (PostgreSQL):
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/deaf_person_db"

# CORS Settings (JSON array format for pydantic)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:19006"]

# Model Paths
SIGN_LANGUAGE_MODEL_PATH=./models/sign_language_model.h5
WHISPER_MODEL_SIZE=base
MODELS_DIR=./models

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./uploads
AVATAR_DIR=./avatar
