# ============================================================================
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
coverage.xml
*.cover
.pytest_cache/

# ============================================================================
# Build / Compiled
# ============================================================================
*.com
*.class
*.dll
*.exe
*.o
*.so

# ============================================================================
# Documentation (Keep essentials only)
# ============================================================================
