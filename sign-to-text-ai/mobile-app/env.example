# ============================================================================
# Sign Language Translation App - Mobile App Environment
# ============================================================================
# Copy this file to .env and update the values
# ============================================================================

# API Configuration
# ============================================================================
# Development: Use your computer's local IP for physical devices
# Example: API_BASE_URL=http://192.168.1.100:8000/api/v1
# Production: Use your deployed backend URL
# Example: API_BASE_URL=https://your-app.railway.app/api/v1
API_BASE_URL=http://192.168.1.9:8000/api/v1

# API Timeout (milliseconds)
API_TIMEOUT=30000

# WebSocket URL (for real-time features)
WS_BASE_URL=ws://192.168.1.9:8000/ws

# Features
# ============================================================================
ENABLE_OFFLINE_MODE=true
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false

# Cache Configuration
# ============================================================================
MAX_CACHE_SIZE_MB=100
CACHE_EXPIRY_DAYS=7

# Development
# ============================================================================
DEBUG_MODE=true
SHOW_API_LOGS=true

